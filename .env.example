# GEMINI_API_KEY: SERVER-SIDE ONLY. Used by the Vercel function api/insight.ts.
# Set this in Vercel Project Settings -> Environment Variables (or `vercel env add`).
# NEVER expose it to the client: no VITE_ prefix, no `define` in vite.config.ts.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Supabase Configuration (anon key is public by design; data is protected by RLS)
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
